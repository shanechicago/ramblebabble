# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored, so these never get committed to GitHub.
#
# To go LIVE: add these same keys in Vercel under
# Project -> Settings -> Environment Variables (one row per key below).

# --- OpenAI (used server-side only) ---
OPENAI_API_KEY=sk-...

# --- Supabase ---
# Project URL and the PUBLIC anon key (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# SECRET service-role key (full admin, server-only, NEVER expose this):
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# --- Optional overrides (defaults shown) ---
# AI_PROVIDER=openai
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_CLEANUP_MODEL=gpt-4o-mini
